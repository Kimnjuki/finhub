{
  "include": [
    "convex/ingestion/*"
  ],
  "composite": true,
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "noImplicitAny": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "allowJs": true,
    "noUnusedLocals": false,
    "strictNullChecks": false,
    "types": ["node"],
    "moduleResolution": "node16",
    "module": "node16",
    "ignoreDeprecations": "6.0"
  }
}
